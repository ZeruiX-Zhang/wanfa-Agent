# Reality OS unified environment template.
# Copy to .env locally when needed. Do not commit real values.

# App
APP_ENV=development
REALITY_OS_HOST=127.0.0.1
REALITY_OS_API_PORT=8010
REALITY_OS_WEB_PORT=3010
REALITY_OS_DESKTOP_MODE=tauri

# Database
DATABASE_URL=postgresql+psycopg://reality_os:reality_os@127.0.0.1:5432/reality_os
POSTGRES_DB=reality_os
POSTGRES_USER=reality_os
POSTGRES_PASSWORD=change-me-locally

# Multi-tenant defaults
DEFAULT_TENANT_ID=local
DEFAULT_USER_ID=local-user
DEFAULT_ROLES=owner,admin
AUTH_ENABLED=false
API_KEY=

# Legacy service ports
SOU_BACKEND_PORT=8001
SOU_FRONTEND_PORT=3001
PROMPT_AGENT_PORT=8787
PROMPT_AGENT_DESKTOP_PORT=1420
WORK_API_PORT=8002
WORK_DESKTOP_MODE=pyside6
WORK_LEGACY_RAG_PORT=8765
WORK_LEGACY_WORKFLOW_PORT=8770
WORK_LEGACY_ANALYST_PORT=8780

# Retrieval infrastructure
REDIS_URL=redis://127.0.0.1:6379/0
QDRANT_URL=http://127.0.0.1:6333
VECTOR_BACKEND=pgvector
RETRIEVAL_MODE=hybrid

# LLM providers
LLM_PROVIDER=mock
OPENAI_API_KEY=
DEEPSEEK_API_KEY=
QWEN_API_KEY=
LOCAL_LLM_API_KEY=
OLLAMA_BASE_URL=http://127.0.0.1:11434

# External search and source providers
BRAVE_SEARCH_API_KEY=
TAVILY_API_KEY=
GITHUB_TOKEN=
PRODUCT_HUNT_TOKEN=
COINGECKO_API_KEY=

# Security
ALLOW_TOOL_EXECUTION=false
REQUIRE_APPROVAL_FOR_HIGH_RISK=true
KNOWLEDGE_WRITES_REQUIRE_REVIEW=true
PROMPT_INJECTION_DETECTION=true
REDACT_SENSITIVE_INFO=true

# ---- expert-coaching-loop feature (additive; safe defaults keep behaviour off) ----
# Vector backend selector. ``sqlite_tfidf`` is the deterministic offline default;
# ``sqlite_embed`` activates the embedding-backed store wired in M3 (R8.5, R18.1).
REALITY_OS_VECTOR_STORE=sqlite_tfidf
# Embedder gate. ``disabled`` = no embedding path; ``offline`` = forces TF-IDF
# fallback with no outbound calls; ``online`` = uses configured embedder slot.
REALITY_OS_EMBED_MODE=disabled
# Dark-launch flags for the coaching loop. Flip per milestone (R15, rollout plan).
REALITY_OS_COACH_ENABLED=false
REALITY_OS_HYBRID_RETRIEVAL=false
REALITY_OS_EXPERT_GAP_ENABLED=false
# When false, Simple_Mode requires explicit user confirmation before applying a
# skill-chain switch (R3.5). Professional_Mode always honours this flag.
REALITY_OS_COACH_AUTOSWITCH=false
# Coaching tunables.
REALITY_OS_CALIBRATION_THRESHOLD=0.6
REALITY_OS_COACH_IDLE_DAYS=30
REALITY_OS_CONSECUTIVE_FAIL_THRESHOLD=3
