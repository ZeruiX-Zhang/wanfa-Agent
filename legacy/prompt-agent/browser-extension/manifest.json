{
  "manifest_version": 3,
  "name": "PromptAgent Input",
  "version": "0.6.0",
  "description": "Send selected text to PromptAgent desktop.",
  "permissions": ["contextMenus", "activeTab", "scripting", "notifications", "storage"],
  "host_permissions": ["http://127.0.0.1:8787/*"],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ],
  "action": {
    "default_popup": "popup.html"
  }
}

