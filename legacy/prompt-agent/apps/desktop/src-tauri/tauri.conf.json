{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "PromptAgent",
  "version": "0.6.0",
  "identifier": "com.promptagent.desktop",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://127.0.0.1:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "PromptAgent",
        "width": 1280,
        "height": 820,
        "minWidth": 1040,
        "minHeight": 720
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": false,
    "targets": "all",
    "icon": []
  }
}

