PLATFORM_ROOT=/app
APP_ENV=dev
API_NAME=Unified AI Workflow Platform
DEMO_MODE=true
API_HOST=0.0.0.0
API_PORT=8000
AUTH_ENABLED=true
API_KEY=change-me
DEFAULT_USER_ID=demo-user
DEFAULT_TENANT_ID=demo
DEFAULT_ROLES=employee,support,finance,ops,legal,analyst,manager

UNIFIED_TRACE_PATH=storage/traces/runs.jsonl
TRACE_STORAGE_DIR=storage/traces
RAG_STORAGE_DIR=storage/rag
TICKET_STORE_PATH=storage/tickets/tickets.jsonl
WORKFLOW_INTERNAL_TRACE_PATH=storage/traces/workflow_internal.jsonl
ANALYST_INTERNAL_TRACE_PATH=storage/traces/analyst_internal.jsonl

ANALYST_DATABASE_URL=sqlite:///storage/analyst/analyst.db
ANALYST_CHART_DIR=storage/analyst/charts
STRUCTURED_DATA_CONNECTOR=sqlite_demo
WAREHOUSE_READONLY_URL=

FINANCE_CSV_PATH=data/finance/financial_metrics.csv
MAX_STEPS_DEFAULT=6
MAX_RESULT_ROWS=100
SQL_TIMEOUT_SECONDS=5
REQUEST_TIMEOUT_SECONDS=10

RETRIEVAL_MODE=hybrid
RERANKER_ENABLED=true
RERANKER_PROVIDER=simple
RETRIEVAL_CANDIDATES=30
RERANK_TOP_N=5
CONTEXTUAL_RETRIEVAL_ENABLED=true
CONTEXTUALIZER_PROVIDER=template
CONTEXTUALIZER_MAX_TOKENS=200
VECTOR_BACKEND=faiss
TRACE_SAMPLE_RATE=1.0

# Unified LLM Gateway. Leave keys empty for mock/demo mode.
OPENAI_API_KEY=
DEEPSEEK_API_KEY=
QWEN_API_KEY=
LOCAL_LLM_API_KEY=
DEFAULT_CHAT_MODEL=mock-chat
DEFAULT_EMBEDDING_MODEL=mock-embedding
DEFAULT_RERANKER_MODEL=mock-reranker

RATE_LIMIT_ENABLED=true
REQUESTS_PER_MINUTE=120
TOKEN_BUDGET_PER_MINUTE=120000
EVENT_LOG_PATH=storage/traces/events.jsonl
