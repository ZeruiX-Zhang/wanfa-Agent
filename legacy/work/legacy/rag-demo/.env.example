# RAG retrieval
RETRIEVAL_MODE=hybrid
DENSE_TOP_K=20
BM25_TOP_K=20
RRF_K=60

# RAG reranking
RERANKER_ENABLED=true
RERANKER_PROVIDER=simple
RETRIEVAL_CANDIDATES=30
RERANK_TOP_N=5

# Contextual retrieval
CONTEXTUAL_RETRIEVAL_ENABLED=true
CONTEXTUALIZER_PROVIDER=template
CONTEXTUALIZER_MAX_TOKENS=200

# Vector backend
VECTOR_BACKEND=faiss
DATABASE_URL=postgresql+psycopg://rag_user:rag_password@localhost:5432/rag_agent_demo
PGVECTOR_INDEX_TYPE=hnsw
PGVECTOR_DISTANCE=cosine

# Auth and access control
RAG_DEMO_HOST=127.0.0.1
RAG_DEMO_PORT=8765
AUTH_ENABLED=true
DEMO_API_KEY=change-me
JWT_SECRET=change-me

# LLM client
LLM_TIMEOUT_SECONDS=60
LLM_MAX_RETRIES=3
EMBEDDING_BATCH_SIZE=64
EMBEDDING_TIMEOUT_SECONDS=60

# Observability
OTEL_ENABLED=false
OTEL_EXPORTER_OTLP_ENDPOINT=
TRACE_SAMPLE_RATE=1.0
RAG_STORAGE_DIR=storage/rag
TRACE_STORAGE_DIR=storage/traces
