APP_NAME=Enterprise RAG Agent Demo
APP_ENV=local
LOG_LEVEL=INFO

CHUNK_SIZE=800
CHUNK_OVERLAP=120

# Chat LLM: DeepSeek V4.
# Use deepseek-v4-flash for lower latency/cost, or deepseek-v4-pro for stronger answers.
DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_CHAT_MODEL=deepseek-v4-flash

# Optional generic chat override. If set, these take precedence over DEEPSEEK_*.
CHAT_API_KEY=
CHAT_BASE_URL=
CHAT_MODEL=

# Embeddings for FAISS. DeepSeek chat keys are not enough unless your provider supports /embeddings.
# Demo mode uses a deterministic local hash embedding when no embedding key is configured.
# This is useful for portfolio screenshots, not for production retrieval quality.
DEMO_EMBEDDINGS_ENABLED=true
LOCAL_EMBEDDING_DIMENSIONS=384
EMBEDDING_API_KEY=
EMBEDDING_BASE_URL=
EMBEDDING_MODEL=

# Legacy OpenAI-compatible fallback. Kept for one-provider setups.
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_CHAT_MODEL=gpt-4o-mini
OPENAI_EMBEDDING_MODEL=text-embedding-3-small
OPENAI_TIMEOUT_SECONDS=60
LLM_MAX_RETRIES=2

# Keep false for most local demos. Set true only if your environment needs HTTP(S)_PROXY vars.
HTTP_TRUST_ENV=false
